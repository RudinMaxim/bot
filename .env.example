NODE_ENV=development

# Приложение
HOST=127.0.0.1
PORT=3500

# Ключи безопасности
# HMAC-ключ для подписи сессионных куки. Обязателен, минимум 32 байта.
SESSION_SIGNING_KEY=dev-session-signing-key-change-me-min-32-bytes-abcdef
# Отдельный JWT-ключ. В продакшене задайте значение, отличное от SESSION_SIGNING_KEY.
JWT_SIGNING_KEY=dev-jwt-signing-key-change-me-min-32-bytes-abcdef

# Настройки сессии
# Пустое значение использует текущий хост.
SESSION_COOKIE_DOMAIN=
# none | lax | strict
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true

# API-ключи интеграции
# Формат: name:sha256hex:role,name2:sha256hex:role
# Роли: admin | read-only. Пустое значение запрещает integration/* запросы без ключей.
INTEGRATION_API_KEYS=

# OpenRouter
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# MAX Bot API
MAX_BOT_TOKEN=
MAX_BOT_API_BASE_URL=https://platform-api.max.ru
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_PATH=/api/v1/max/webhook
MAX_WEBHOOK_BASE_URL=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Postgres
# Приложение читает POSTGRES_URL. Docker Compose также использует POSTGRES_DB/USER/PASSWORD.
POSTGRES_URL=postgres://postgres:postgres@postgres:5432/developer-ai
POSTGRES_DB=developer-ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# CORS
CORS_ORIGINS=http://localhost:4000

# Swagger
SWAGGER_ENABLED=false

# Подключения эмбеддингов и векторного хранилища
EMBEDDING_VECTORIZATION_PROVIDER=ollama
EMBEDDING_VECTORIZATION_MODEL=nomic-embed-text
EMBEDDING_VECTORIZATION_URL=http://ollama:11434
EMBEDDING_DATABASE_PROVIDER=weaviate
EMBEDDING_DATABASE_URL=http://weaviate:8080
EMBEDDING_DATABASE_API_KEY=

# Расширенные рантайм-настройки уже имеют дефолты в src/infrastructure/config.
# Добавляйте дополнительные env-переменные только для осознанного переопределения в конкретном окружении.

# Docker build flag. If true, server image installs Chromium for Playwright fallback.
INSTALL_PLAYWRIGHT_BROWSER=false
