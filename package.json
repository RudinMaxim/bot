{
  "name": "developer-ai",
  "version": "0.1.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:backend",
    "build:backend": "nest build -p tsconfig.build.json",
    "build:client": "npm --prefix ../client run build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "db:migrate": "npm run db:migration:run",
    "db:migration:run": "node scripts/db-command.js migration:run",
    "db:migration:run:local": "node scripts/db-command.js migration:run --mode=ts",
    "db:migration:revert": "node scripts/db-command.js migration:revert",
    "db:migration:generate": "node scripts/db-command.js migration:generate",
    "db:seed": "node scripts/db-command.js seed",
    "search-base:refresh": "node -r ts-node/register -r tsconfig-paths/register scripts/search-base-refresh.ts",
    "typecheck": "npm run typecheck:backend",
    "typecheck:backend": "tsc --noEmit -p tsconfig.build.json",
    "typecheck:client": "npm --prefix ../client run type-check",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src test/e2e --ext .ts --ignore-pattern \"src/**/dist/**\" --fix && npm run typecheck",
    "bench": "jest --config test/e2e/jest-e2e.config.ts --runInBand test/e2e/pipeline-benchmark.e2e-spec.ts",
    "bench:stats": "node scripts/bench-stats.js",
    "integration:key": "node scripts/generate-integration-api-key.cjs"
  },
  "dependencies": {
    "@langchain/core": "^0.3.73",
    "@langchain/openai": "^0.6.11",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fast-xml-parser": "^4.5.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^0.3.32",
    "pg": "^8.13.1",
    "playwright": "^1.59.1",
    "reflect-metadata": "^0.2.2",
    "robots-parser": "^3.0.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.19",
    "weaviate-ts-client": "^2.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
